# Shell environment configuration

# nvm setup
export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/share/nvm/nvm.sh" ] && \. "/opt/homebrew/share/nvm/nvm.sh"  # ARM Macs
[ -s "/usr/local/share/nvm/nvm.sh" ] && \. "/usr/local/share/nvm/nvm.sh"      # Intel Macs
[ -s "/opt/homebrew/share/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/share/nvm/etc/bash_completion.d/nvm"  # nvm bash_completion
